{
  "name": "command-code-gui",
  "version": "0.1.0",
  "description": "Native desktop workbench for wrapping the Command Code CLI.",
  "main": "out/main/index.js",
  "private": true,
  "author": "Vel Labs",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "doctor": "tsx src/cli/ccgui.ts doctor",
    "serve": "npm run build && tsx src/cli/ccgui.ts serve",
    "dev:server": "tsx src/cli/ccgui.ts serve",
    "dev:web": "vite --config vite.web.config.ts",
    "smoke:headless": "tsx scripts/smoke-headless.ts",
    "smoke:server": "tsx scripts/smoke-server.ts",
    "smoke:browser": "tsx scripts/smoke-browser.ts",
    "smoke:pty": "tsx scripts/smoke-pty.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^1.17.0",
    "node-pty": "^1.2.0-beta.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "ai.commandcode.gui",
    "productName": "Command Code",
    "files": [
      "out/**",
      "package.json"
    ],
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "build/icon.png"
    }
  }
}
